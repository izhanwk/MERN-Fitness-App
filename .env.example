PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Frontend
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Auth
SECRET_KEY=replace-with-a-long-random-access-token-secret
REFRESH=replace-with-a-long-random-refresh-token-secret
JWT_VERIFY=replace-with-a-long-random-email-verification-secret
JWT_ACCESS_EXPIRES_IN=5m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EMAIL_VERIFY_EXPIRES_IN=1h

# App URLs
SERVER_BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.example
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Gmail OAuth mail delivery
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-oauth-refresh-token
GMAIL_SENDER=you@example.com
